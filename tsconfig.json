{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "main.js", "main.js.map", "dist", ".test-dist"]
}
